# Local development — SQLite (no setup needed)
DATABASE_URL=sqlite:///./data/briefit.db

# Production — PostgreSQL (set this in your Render/VPS environment)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/briefit

JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

GROQ_API_KEY_SENTIMENT=
GROQ_API_KEY_SUMMARIZE=
GROQ_MODEL_SENTIMENT=llama-3.1-8b-instant
GROQ_MODEL_SUMMARIZE=llama3-8b-8192
OPENAI_API_KEY=
